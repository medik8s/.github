SNR_VERSION=0.12.0
SNR_PREVIOUS=0.11.0

FAR_VERSION=0.7.0
FAR_PREVIOUS=0.6.0

NMO_VERSION=0.20.0
NMO_PREVIOUS=0.19.0

NHC_VERSION=0.11.0
NHC_PREVIOUS=0.10.0
NHC_SKIP_RANGE_LOWER=">=0.8.0"

MDR_VERSION=0.6.0
MDR_PREVIOUS=0.5.0
